{
  "name": "webu-portal",
  "private": true,
  "packageManager": "pnpm@10.8.1",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "docker compose up --build",
    "down": "docker compose down -v",
    "lint": "pnpm -r lint",
    "lint:check": "pnpm -r lint:check",
    "format": "pnpm -r format",
    "format:check": "pnpm -r format:check",
    "typecheck": "pnpm prisma:generate && pnpm -r typecheck",
    "build": "pnpm prisma:generate && pnpm -r build",
    "prisma:generate": "pnpm --filter service exec prisma generate",
    "prisma:migrate": "pnpm --filter service exec prisma migrate dev",
    "prisma:studio": "pnpm --filter service exec prisma studio",
    "prisma:seed": "pnpm --filter service run db:seed",
    "prisma:seed:admin-emails": "pnpm --filter service run db:seed:admin-emails"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4"
  }
}
